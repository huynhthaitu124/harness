    ("mcp register", "mcp register", "Register harness server in .mcp.json + ~/.gemini/* configs"),
    ("mcp status",   "mcp status",   "Show MCP registration state across all agent configs"),
    ("center",       "center",       "Set preferred routing center: auto / codex / claude / antigravity"),
    ("status",       "status",       "Show routing center, memory, features, MCP health"),
    ("index",        "index",        "Build / rebuild BM25 + semantic RAG index"),
    ("grill",        "grill",        "Q&A session — fills [CUSTOMIZE] section in HARNESS.md"),
    ("analyze",      "analyze",      "Print project profile JSON (language, framework, entry points)"),
    ("eject",        "eject",        "Remove .harness/, HARNESS.md, HARNESS.html from project"),
]

# Flat command reference printed before the TUI when harness is run with no args
_ALL_COMMANDS: list[tuple[str, str]] = [
    ("harness init",               "Full project init: detect stack → agent research → write HARNESS.html"),
    ("harness update",             "Pull latest harness; optionally regenerate docs/MCP for this project"),
