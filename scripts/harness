#!/usr/bin/env python3
"""Harness CLI — interactive TUI when run with no subcommand, direct mode otherwise."""
from __future__ import annotations

import argparse
import json
import os
import shutil
import sys
from pathlib import Path

HARNESS_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(HARNESS_ROOT))


def _project_root(path: str | None) -> Path:
    root = Path(path).expanduser().resolve() if path else Path(os.getcwd())
    if not root.exists():
        print(f"error: path does not exist: {root}", file=sys.stderr)
        sys.exit(2)
    return root


# ─────────────────────────────────────────────────────────────────────────────
# Pretty output helpers  (Ollama-style — no JSON noise)
# ─────────────────────────────────────────────────────────────────────────────

_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stdout.isatty()

def _c(code: str) -> str:
    return "" if _NO_COLOR else code

G  = _c("\x1b[32m")   # green
C  = _c("\x1b[36m")   # cyan
Y  = _c("\x1b[33m")   # yellow
DIM = _c("\x1b[2m")
B  = _c("\x1b[1m")
R  = _c("\x1b[0m")


def _ok(msg: str)   -> None: print(f"  {G}✓{R}  {msg}")
def _info(msg: str) -> None: print(f"  {C}·{R}  {msg}")
def _warn(msg: str) -> None: print(f"  {Y}!{R}  {msg}")
def _row(label: str, value: str) -> None:
    print(f"  {DIM}{label:<18}{R}{B}{value}{R}")


# ─────────────────────────────────────────────────────────────────────────────
# Command implementations  (unchanged logic, called both from TUI and CLI)
# ─────────────────────────────────────────────────────────────────────────────

HARNESS_PATHS = [".harness", "HARNESS.md", "HARNESS.html", "configs/claude-mcp.json"]


def run_init(target: Path, *, dry_run: bool = False, skip_index: bool = False,
             from_analysis: str | None = None) -> int:
    from harness_core.project_init import analyze_project, init_project_full

    print(f"\n{B}Analyzing{R} {DIM}{target.name}{R} ...")

    if from_analysis:
        p = Path(from_analysis).expanduser()
        if not p.exists():
            _warn(f"analysis file not found: {p}")
            return 2
        analysis = json.loads(p.read_text(encoding="utf-8"))
    else:
        analysis = analyze_project(target)

    lang      = analysis.get("language", "unknown")
    fw        = analysis.get("framework", "")
    secondary = analysis.get("secondary_languages", [])
    stack     = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(secondary)}" if secondary else "")
    _row("Stack",    stack)
    _row("Project",  analysis.get("project_name", target.name))
    entries = analysis.get("entry_points", [])
    if entries:
        _row("Entry points", str(len(entries)))

    agents = analysis.get("agents", [])
    if agents:
        names = ", ".join(a["agent"] for a in agents)
        _row("Agents found", names)

    if dry_run:
        _warn("dry-run — no files will be written")
        return 0

    print()
    result = init_project_full(target, HARNESS_ROOT, analysis, dry_run=False, skip_index=skip_index)
    _install_symlink(result)

    created = result.get("created", [])
    # Show only the meaningful artifacts, not every individual file
    artifacts = [
        (".harness/", "configuration + BM25 index"),
        ("HARNESS.md", "project guidelines doc"),
        ("HARNESS.html", "visual architecture doc"),
        ("configs/claude-mcp.json", "MCP server config"),
        ("production_artifacts/memory.jsonl", "seeded memory records"),
    ]
    for rel, desc in artifacts:
        matched = any(rel.rstrip("/") in c for c in created)
        if matched:
            _ok(f"{B}{rel}{R}  {DIM}{desc}{R}")

    print()
    if not skip_index:
        _maybe_build_semantic_index(target)

    return 0


def run_eject(target: Path, *, dry_run: bool = False) -> int:
    removed: list[str] = []

    for rel in HARNESS_PATHS:
        path = target / rel
        if not path.exists():
            continue
        if dry_run:
            _info(f"would remove  {DIM}{rel}{R}")
        else:
            shutil.rmtree(path) if path.is_dir() else path.unlink()
            _ok(f"removed  {DIM}{rel}{R}")
        removed.append(rel)

    configs_dir = target / "configs"
    if configs_dir.exists() and not any(configs_dir.iterdir()):
        if not dry_run:
            configs_dir.rmdir()
        removed.append("configs/")

    if not removed:
        _info("nothing to remove — project was not initialized")
    else:
        print()
        _info(f"kept  {DIM}production_artifacts/{R}  (data preserved)")

    return 0


def run_analyze(target: Path) -> int:
    from harness_core.project_init import analyze_project

    print(f"\n{B}Analyzing{R} {DIM}{target.name}{R} ...")
    a = analyze_project(target)

    lang      = a.get("language", "unknown")
    fw        = a.get("framework", "")
    secondary = a.get("secondary_languages", [])
    stack     = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(secondary)}" if secondary else "")

    print()
    _row("Stack",    stack)
    _row("Project",  a.get("project_name", target.name))

    entries = a.get("entry_points", [])
    for i, e in enumerate(entries[:5]):
        label = "Entry points" if i == 0 else ""
        _row(label, Path(e).name)

    kw_research = a.get("routing_keywords", {}).get("research_heavy_keywords", [])
    kw_coding   = a.get("routing_keywords", {}).get("coding_keywords", [])
    if kw_research:
        _row("Research keys", ", ".join(kw_research[:5]))
    if kw_coding:
        _row("Coding keys",   ", ".join(kw_coding[:5]))

    features = a.get("initial_features", [])
    if features:
        print()
        _info(f"{len(features)} features seeded")
    memories = a.get("initial_memories", [])
    if memories:
        _info(f"{len(memories)} memory records ready")
    print()
    return 0


def run_grill(target: Path) -> int:
    from harness_core.project_analyzer import run_grill_session, write_grill_answers_to_harness_md
    from harness_core.project_init import analyze_project

    harness_md = target / "HARNESS.md"
    if not harness_md.exists():
        print("error: HARNESS.md not found — run init first")
        return 2

    project_json = target / ".harness" / "project.json"
    if project_json.exists():
        meta = json.loads(project_json.read_text(encoding="utf-8"))
        language     = meta.get("language", "unknown")
        framework    = meta.get("framework", "")
        project_name = meta.get("project_name", target.name)
    else:
        a = analyze_project(target)
        language, framework, project_name = a["language"], a["framework"], a["project_name"]

    answers = run_grill_session(target, language, framework, project_name)
    if not answers:
        print("\nNo answers recorded. HARNESS.md unchanged.")
        return 0

    write_grill_answers_to_harness_md(harness_md, answers)
    print(f"\n✓ {len(answers)} answer(s) written to {harness_md}")
    return 0


def run_index(target: Path) -> int:
    if not (target / ".harness").exists():
        print("error: not initialized — run init first")
        return 2
    _maybe_build_semantic_index(target)
    return 0


def run_status(target: Path) -> int:
    state_path   = target / ".harness" / "state.json"
    project_json = target / ".harness" / "project.json"
    memory_path  = target / "production_artifacts" / "memory.jsonl"
    feature_path = target / "production_artifacts" / "feature_list.json"
    semantic_idx = target / "production_artifacts" / "indexes" / "semantic.json"

    print()
    if not state_path.exists():
        _warn("not initialized — run  harness init")
        return 0

    if project_json.exists():
        d    = json.loads(project_json.read_text(encoding="utf-8"))
        lang = d.get("language", "?")
        fw   = d.get("framework", "")
        sec  = d.get("secondary_languages", [])
        stack = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(sec)}" if sec else "")
        _row("Project",   d.get("project_name", target.name))
        _row("Stack",     stack)
        _row("Analyzed",  d.get("analyzed_at", "")[:10])

        agents = d.get("agents", [])
        if agents:
            for i, a in enumerate(agents):
                label = "Agents" if i == 0 else ""
                _row(label, f"{a['agent']}  {DIM}{a['path']}{R}")

    if state_path.exists():
        state  = json.loads(state_path.read_text(encoding="utf-8"))
        center = state.get("preferred_center", "auto")
        _row("Center",    center)

    print()
    if memory_path.exists():
        n = sum(1 for l in memory_path.read_text(encoding="utf-8").splitlines() if l.strip())
        _row("Memory",    f"{n} records")
    else:
        _row("Memory",    "0 records")

    if feature_path.exists():
        features = json.loads(feature_path.read_text(encoding="utf-8")).get("features", [])
        done     = sum(1 for f in features if f.get("status") == "done")
        bar      = ("█" * done + "░" * (len(features) - done)) if features else ""
        _row("Features",  f"{done}/{len(features)}  {DIM}{bar}{R}")

    bm25 = target / ".harness" / "index.json"
    _row("BM25 index",  f"{G}ready{R}" if bm25.exists() else f"{Y}missing{R}")
    _row("Semantic idx", f"{G}ready{R}" if semantic_idx.exists() else f"{DIM}not built{R}")
    print()
    return 0


# ─────────────────────────────────────────────────────────────────────────────
# Semantic index helpers
# ─────────────────────────────────────────────────────────────────────────────

def _maybe_build_semantic_index(target: Path) -> None:
    from harness_core.semantic_index import detect_ollama, build_semantic_index, ollama_embed
    from harness_core.tui import confirm, select, MenuItem, menu

    embed_models, other_models = detect_ollama()
    all_models = embed_models + other_models

    if not all_models:
        _warn("Ollama not running — semantic index skipped")
        _info("start Ollama, pull a model, then:  harness  →  index")
        return

    if not confirm("Build semantic RAG index with Ollama?", default=True):
        _info("semantic index skipped")
        return

    # Build menu items — embedding models first with a clear label
    items: list[MenuItem] = []
    for m in embed_models:
        items.append(MenuItem(key=m, label=m, desc="✓ embedding model — fast & accurate"))
    for m in other_models:
        items.append(MenuItem(key=m, label=m,
                              desc="⚠ chat/code model — slow for embeddings, may fail"))

    if not embed_models:
        _warn("no dedicated embedding model found")
        _info("chat models are slow for embeddings — recommended: ollama pull nomic-embed-text")
        print()

    chosen = menu("Select Ollama model for embeddings:", items)
    if chosen is None:
        _info("semantic index skipped")
        return

    index_path = target / "production_artifacts" / "indexes" / "semantic.json"
    index_path.parent.mkdir(parents=True, exist_ok=True)

    print()
    _info(f"building semantic index with  {B}{chosen}{R} ...")
    if chosen in other_models:
        _warn("chat model selected — first run may be slow")

    try:
        stats   = build_semantic_index(target, index_path,
                                        embedder=lambda t: ollama_embed(t, model=chosen),
                                        model=chosen)
        total   = stats.get("chunk_count", "?")
        reused  = stats.get("reused_count", 0)
        new_vec = stats.get("embedded_count", total)
        _ok(f"semantic index ready  {DIM}{total} chunks  ({new_vec} embedded, {reused} cached){R}")
    except Exception as exc:
        _warn(f"semantic index failed: {exc}")
        if chosen in other_models:
            _info("fix: ollama pull nomic-embed-text  then retry: harness  →  index")


def _install_symlink(result: dict) -> None:
    this_script = Path(__file__).resolve()
    candidates  = [Path("/usr/local/bin/harness"), Path.home() / ".local" / "bin" / "harness"]
    symlink: Path | None = None

    for candidate in candidates:
        try:
            candidate.parent.mkdir(parents=True, exist_ok=True)
            if candidate.is_symlink() or candidate.exists():
                if Path(os.readlink(candidate)).resolve() == this_script:
                    print(f"[harness init] already installed: {candidate}")
                    result["symlink"] = str(candidate)
                    return
                candidate.unlink()
            candidate.symlink_to(this_script)
            symlink = candidate
            break
        except PermissionError:
            continue

    if symlink is None:
        _warn("could not install harness command (permission denied)")
        return

    _ok(f"installed  {DIM}{symlink}{R}")
    result["symlink"] = str(symlink)

    if symlink.parent == Path.home() / ".local" / "bin":
        _ensure_path(symlink.parent)


def _ensure_path(bin_dir: Path) -> None:
    marker = str(bin_dir)
    for rc in (Path.home() / ".zshrc", Path.home() / ".bashrc"):
        if rc.exists() and marker in rc.read_text(encoding="utf-8"):
            return
    zshrc = Path.home() / ".zshrc"
    try:
        with zshrc.open("a", encoding="utf-8") as f:
            f.write(f'\nexport PATH="{marker}:$PATH"  # added by harness init\n')
        _info(f"added {DIM}{marker}{R} to PATH in ~/.zshrc — run: source ~/.zshrc")
    except OSError as exc:
        _warn(f"could not update ~/.zshrc: {exc}")


# ─────────────────────────────────────────────────────────────────────────────
# Interactive menu  (Ollama style — ANSI inline, no curses)
# ─────────────────────────────────────────────────────────────────────────────

_VERSION = "1.0"

_MENU_ITEMS = [
    ("init",    "Initialize harness for this project",
                "Detect stack, build BM25 + semantic RAG index, write HARNESS.md"),
    ("index",   "Build / rebuild semantic RAG index",
                "Pick Ollama model interactively, embed all chunks"),
    ("grill",   "Fill [CUSTOMIZE] section interactively",
                "Q&A session that writes project context into HARNESS.md"),
    ("status",  "Show project state",
                "Memory records, feature progress, routing policy"),
    ("analyze", "Analyze project and print profile",
                "Language detection, keywords, key files — JSON output"),
    ("eject",   "Remove harness config, keep data",
                "Deletes .harness/, HARNESS.md, HARNESS.html — keeps production_artifacts/"),
]


def _project_info(target: Path) -> str:
    pj = target / ".harness" / "project.json"
    if pj.exists():
        try:
            d    = json.loads(pj.read_text(encoding="utf-8"))
            lang = d.get("language", "?")
            fw   = d.get("framework", "")
            name = d.get("project_name", target.name)
            tag  = f"{lang}" + (f"/{fw}" if fw else "")
            return f"{name}  [{tag}]  ● initialized"
        except Exception:
            pass
    return f"{target.name}  ○ not initialized"


def launch_menu(target: Path) -> None:
    from harness_core.tui import MenuItem, menu, confirm

    items = [MenuItem(key=k, label=lbl, desc=desc) for k, lbl, desc in _MENU_ITEMS]

    info  = _project_info(target)
    title = f"Harness {_VERSION}   \x1b[2m{info}\x1b[0m"

    while True:
        chosen = menu(title, items, version="")
        if chosen is None:
            break

        print(f"\n\x1b[1;36m── harness {chosen} ──\x1b[0m\n")

        try:
            if chosen == "init":
                run_init(target)
            elif chosen == "eject":
                ok = confirm(
                    "Remove .harness/, HARNESS.md, HARNESS.html, configs/claude-mcp.json?",
                    default=False,
                )
                if ok:
                    run_eject(target)
                else:
                    print("  cancelled")
            elif chosen == "analyze":
                run_analyze(target)
            elif chosen == "grill":
                run_grill(target)
            elif chosen == "index":
                run_index(target)
            elif chosen == "status":
                run_status(target)
        except KeyboardInterrupt:
            print("\n  interrupted")

        print()
        input("\x1b[2m  press Enter to return to menu…\x1b[0m")
        print()

        # refresh info line after command may have changed state
        info  = _project_info(target)
        title = f"Harness {_VERSION}   \x1b[2m{info}\x1b[0m"


# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="harness",
        description="Tri-center harness — no args opens interactive TUI.",
        add_help=True,
    )
    parser.add_argument("--path", "-p", metavar="PATH",
                        help="Target project path (default: cwd)")
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    p_init = sub.add_parser("init",    help="Initialize harness")
    p_init.add_argument("--dry-run",      action="store_true")
    p_init.add_argument("--skip-index",   action="store_true")
    p_init.add_argument("--from-analysis", metavar="FILE")

    p_eject = sub.add_parser("eject",   help="Remove harness config, keep data")
    p_eject.add_argument("--dry-run", action="store_true")

    sub.add_parser("analyze", help="Print project profile JSON")
    sub.add_parser("grill",   help="Fill [CUSTOMIZE] section interactively")
    sub.add_parser("status",  help="Show harness state")
    sub.add_parser("index",   help="Build/rebuild semantic RAG index")

    for p in sub.choices.values():
        p.add_argument("path", nargs="?", default=None, metavar="PATH")

    args = parser.parse_args()
    target = _project_root(getattr(args, "path", None) or args.path if hasattr(args, "path") else None)

    # ── no subcommand → open interactive menu ────────────────────────────────
    if not args.command:
        launch_menu(target)
        return 0

    # ── direct subcommand (for scripting / CI) ────────────────────────────────
    if args.command == "init":
        return run_init(target, dry_run=args.dry_run, skip_index=args.skip_index,
                        from_analysis=getattr(args, "from_analysis", None))
    if args.command == "eject":
        return run_eject(target, dry_run=args.dry_run)
    if args.command == "analyze":
        return run_analyze(target)
    if args.command == "grill":
        return run_grill(target)
    if args.command == "index":
        return run_index(target)
    if args.command == "status":
        return run_status(target)

    parser.print_help()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
