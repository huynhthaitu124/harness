def _project_info(target: Path) -> str:
    pj = target / ".harness" / "project.json"
    if pj.exists():
        try:
            d    = json.loads(pj.read_text(encoding="utf-8"))
            lang = d.get("language", "?")
            fw   = d.get("framework", "")
            name = d.get("project_name", target.name)
            tag  = f"{lang}" + (f"/{fw}" if fw else "")
            return f"{name}  [{tag}]  ● initialized"
        except Exception:
            pass
    return f"{target.name}  ○ not initialized"


def _pick_center(target: Path) -> None:
    """Interactive center picker — shows current center and lets user change it."""
    from harness_core.tui import MenuItem, menu

    # Read current center from state
    state_path = target / ".harness" / "state.json"
    current = "auto"
    if state_path.exists():
        try:
            current = json.loads(state_path.read_text(encoding="utf-8")).get("preferred_center", "auto")
        except Exception:
            pass

    _row("Current center", current)
    print()

    _CENTER_DESCRIPTIONS = {
        "auto":        "Let harness pick per task — reads keywords + quota + token cost",
        "codex":       "Heavy codegen, repo-wide refactor, long multi-file edits",
        "claude":      "Compact review, quick fixes, debugging, analysis",
        "antigravity": "Broad research, large-context reads, architecture planning",
    }

    items: list[MenuItem] = []
    for c, desc in _CENTER_DESCRIPTIONS.items():
        marker = "  ← current" if c == current else ""
        items.append(MenuItem(key=c, label=f"{c}{marker}", desc=desc))

    chosen = menu("Choose preferred center:", items)
    if chosen is None:
        _info("cancelled — center unchanged")
        return

    run_center(target, action="set", value=chosen)


def launch_menu(target: Path) -> None:
    from harness_core.tui import MenuItem, menu, confirm, prompt_input

    items = [MenuItem(key=k, label=lbl, desc=desc) for k, lbl, desc in _MENU_ITEMS]

    info  = _project_info(target)
    title = f"Harness {_VERSION}   {DIM}{info}{R}"

    while True:
        chosen = menu(title, items, compact=True)
        if chosen is None:
            break

        print(f"\n{C}── {chosen} ──{R}\n")

        try:
            if chosen == "workflow":
                run_workflow_cmd(target)
            elif chosen == "agents":
                run_agents_cmd(target)
            elif chosen == "init":
                run_init(target)
            elif chosen == "update":
                run_update(target)
            elif chosen == "run":
                task = prompt_input(f"  {DIM}Task (esc=cancel):{R} ")
                if task:
                    run_ticket(target, task, ticket_id=None, agent_name=None)
            elif chosen == "rag-pack":
                query = prompt_input(f"  {DIM}Task/query (esc=cancel):{R} ")
                if query:
                    run_rag_pack(target, query=query)
            elif chosen == "local plan":
                task = prompt_input(f"  {DIM}Task (esc=cancel):{R} ")
                if task:
                    run_local_plan(target, task=task, complexity="complex", schema_json=None, embedding_model=None)
            elif chosen == "readiness":
                run_readiness(target)
            elif chosen == "research-refresh":
                run_research_refresh(target)
            elif chosen == "usage report":
                run_usage_cmd(target, action="report")
            elif chosen == "mcp register":
                run_mcp(target, "register")
            elif chosen == "mcp status":
                run_mcp(target, "status")
            elif chosen == "mcp security":
                run_mcp(target, "security")
            elif chosen == "center":
                _pick_center(target)
            elif chosen == "status":
                run_status(target)
            elif chosen == "index":
                run_index(target)
            elif chosen == "grill":
                run_grill(target)
            elif chosen == "analyze":
                run_analyze(target)
            elif chosen == "eject":
                ok = confirm("Remove .harness/, HARNESS.md, HARNESS.html?", default=False)
                if ok:
                    run_eject(target)
                else:
                    print("  cancelled")
        except KeyboardInterrupt:
            print("\n  interrupted")

        print()
        info  = _project_info(target)
        title = f"Harness {_VERSION}   {DIM}{info}{R}"


# ─────────────────────────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────────────────────────

def main() -> int:
    parser = argparse.ArgumentParser(
        prog="harness",
        description="Tri-center harness — no args opens interactive TUI.",
        add_help=True,
    )
    parser.add_argument("--path", "-p", metavar="PATH",
                        help="Target project path (default: cwd)")
    sub = parser.add_subparsers(dest="command", metavar="<command>")

    p_init = sub.add_parser("init",    help="Initialize harness")
    p_init.add_argument("--dry-run",      action="store_true")
    p_init.add_argument("--skip-index",   action="store_true")
    p_init.add_argument("--from-analysis", metavar="FILE")

    p_eject = sub.add_parser("eject",   help="Remove harness config, keep data")
    p_eject.add_argument("--dry-run", action="store_true")

    p_center = sub.add_parser("center", help="Get or set this project's preferred center")
    center_sub = p_center.add_subparsers(dest="center_action", metavar="<get|set>", required=True)
    p_center_get = center_sub.add_parser("get", help="Show this project's preferred center")
    p_center_get.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_center_set = center_sub.add_parser("set", help="Set this project's preferred center")
    p_center_set.add_argument("center_value", choices=["auto", "codex", "claude", "antigravity"])
    p_center_set.add_argument("path", nargs="?", default=None, metavar="PATH")

    p_rag = sub.add_parser("rag-pack", help="Build a shared RAG context pack for Codex, Claude, Antigravity, and local Ollama")
    p_rag.add_argument("query", help="Task/query to retrieve context for")
    p_rag.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_rag.add_argument("--center", choices=["project", "auto", "codex", "claude", "antigravity"], default="project")
    p_rag.add_argument("--local-model", default=None)

    p_local = sub.add_parser("local", help="Plan local Ollama embedding and structured-worker usage")
    local_sub = p_local.add_subparsers(dest="local_action", metavar="<plan>", required=True)
    p_local_plan = local_sub.add_parser("plan", help="Plan local RAG/structured worker for a task")
    p_local_plan.add_argument("task")
    p_local_plan.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_local_plan.add_argument("--complexity", choices=["light", "complex", "heavy", "rag-large"], default="complex")
    p_local_plan.add_argument("--schema-json", default=None)
    p_local_plan.add_argument("--embedding-model", default=None, help="auto, qwen3-embedding, embeddinggemma, all-minilm, or another installed embedding model")

    p_research_refresh = sub.add_parser("research-refresh", help="Refresh the default official research registry")
    p_research_refresh.add_argument("--force", action="store_true")
    sub.add_parser("readiness", help="Show live Codex/Claude/Antigravity/Ollama readiness")

    p_usage = sub.add_parser("usage", help="Report or ingest measured Codex/Claude token usage")
    usage_sub = p_usage.add_subparsers(dest="usage_action", metavar="<report|ingest-claude|ingest-codex>", required=True)
    p_usage_report = usage_sub.add_parser("report", help="Summarize production_artifacts/usage.jsonl")
    p_usage_report.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_usage_claude = usage_sub.add_parser("ingest-claude", help="Parse Claude JSON output into usage ledger")
    p_usage_claude.add_argument("raw_file")
    p_usage_claude.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_usage_claude.add_argument("--label", default=None)
    p_usage_codex = usage_sub.add_parser("ingest-codex", help="Parse Codex JSONL output into usage ledger")
    p_usage_codex.add_argument("raw_file")
    p_usage_codex.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_usage_codex.add_argument("--label", default=None)

    sub.add_parser("workflow", help="Agent-driven task: grill session → spec HTML → agent executes")
    sub.add_parser("agents",   help="Install, auth, and configure Claude Code / Codex / Antigravity / Ollama")
    sub.add_parser("analyze",  help="Print project profile JSON")
    sub.add_parser("grill",    help="Fill [CUSTOMIZE] section interactively")
    sub.add_parser("status",   help="Show harness state")
    sub.add_parser("index",    help="Build/rebuild semantic RAG index")

    p_run = sub.add_parser("run", help="Build RAG pack for a task and launch the selected agent with context pre-loaded")
    p_run.add_argument("task", help="Task description or ticket title")
    p_run.add_argument("--ticket", default=None, metavar="ID", help="Ticket ID (e.g. WT-102, OP-456)")
    p_run.add_argument("--agent", default=None, metavar="NAME", help="Agent to use: claude, codex, ollama:<model>")
    p_run.add_argument("path", nargs="?", default=None, metavar="PATH")

    sub.add_parser("update",  help="Pull latest harness from GitHub; optionally refresh project files")

    p_mcp = sub.add_parser("mcp", help="Manage MCP server registration across all agent configs")
    mcp_sub = p_mcp.add_subparsers(dest="mcp_action", metavar="<status|register|unregister|security>", required=True)
    p_mcp_status = mcp_sub.add_parser("status", help="Show registration state in each agent's config file")
    p_mcp_status.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_mcp_register = mcp_sub.add_parser("register", help="Register harness MCP server in all installed agent configs")
    p_mcp_register.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_mcp_unregister = mcp_sub.add_parser("unregister", help="Remove harness from all agent config files")
    p_mcp_unregister.add_argument("path", nargs="?", default=None, metavar="PATH")
    p_mcp_security = mcp_sub.add_parser("security", help="Audit MCP tool safety and command-policy coverage")
    p_mcp_security.add_argument("path", nargs="?", default=None, metavar="PATH")

    for name, p in sub.choices.items():
        if name not in {"center", "rag-pack", "run", "mcp", "update", "local", "usage"}:
            p.add_argument("path", nargs="?", default=None, metavar="PATH")

    args = parser.parse_args()
    target = _project_root(getattr(args, "path", None) or args.path if hasattr(args, "path") else None)

    # ── no subcommand → open interactive menu ────────────────────────────────
    if not args.command:
        launch_menu(target)
        return 0

    # ── direct subcommand (for scripting / CI) ────────────────────────────────
    if args.command == "workflow":
        return run_workflow_cmd(target)
    if args.command == "agents":
        return run_agents_cmd(target)
    if args.command == "init":
        return run_init(target, dry_run=args.dry_run, skip_index=args.skip_index,
                        from_analysis=getattr(args, "from_analysis", None))
    if args.command == "eject":
        return run_eject(target, dry_run=args.dry_run)
    if args.command == "center":
        return run_center(target, action=args.center_action, value=getattr(args, "center_value", None))
    if args.command == "rag-pack":
        return run_rag_pack(target, query=args.query, center=args.center, local_model=args.local_model)
    if args.command == "local":
        return run_local_plan(
            target,
            task=args.task,
            complexity=args.complexity,
            schema_json=args.schema_json,
            embedding_model=args.embedding_model,
        )
    if args.command == "research-refresh":
        return run_research_refresh(target, force=getattr(args, "force", False))
    if args.command == "readiness":
        return run_readiness(target)
    if args.command == "usage":
        return run_usage_cmd(
            target,
            action=args.usage_action,
            raw_file=getattr(args, "raw_file", None),
            center="claude" if args.usage_action == "ingest-claude" else "codex" if args.usage_action == "ingest-codex" else None,
            label=getattr(args, "label", None),
        )
    if args.command == "analyze":
        return run_analyze(target)
    if args.command == "grill":
        return run_grill(target)
    if args.command == "index":
        return run_index(target)
    if args.command == "status":
        return run_status(target)
    if args.command == "run":
        return run_ticket(target, args.task, ticket_id=getattr(args, "ticket", None), agent_name=getattr(args, "agent", None))
    if args.command == "update":
        return run_update(target)
    if args.command == "mcp":
        return run_mcp(target, args.mcp_action)

    parser.print_help()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
