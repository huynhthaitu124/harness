#!/usr/bin/env python3
"""Harness CLI — interactive TUI when run with no subcommand, direct mode otherwise."""
from __future__ import annotations

import argparse
import json
import os
import shutil
import sys
from pathlib import Path

HARNESS_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(HARNESS_ROOT))


def _project_root(path: str | None) -> Path:
    root = Path(path).expanduser().resolve() if path else Path(os.getcwd())
    if not root.exists():
        print(f"error: path does not exist: {root}", file=sys.stderr)
        sys.exit(2)
    return root


# ─────────────────────────────────────────────────────────────────────────────
# Pretty output helpers  (Ollama-style — no JSON noise)
# ─────────────────────────────────────────────────────────────────────────────

_NO_COLOR = bool(os.environ.get("NO_COLOR")) or not sys.stdout.isatty()

def _c(code: str) -> str:
    return "" if _NO_COLOR else code

G  = _c("\x1b[32m")   # green
C  = _c("\x1b[36m")   # cyan
Y  = _c("\x1b[33m")   # yellow
DIM = _c("\x1b[2m")
B  = _c("\x1b[1m")
R  = _c("\x1b[0m")


def _ok(msg: str)   -> None: print(f"  {G}✓{R}  {msg}")
def _info(msg: str) -> None: print(f"  {C}·{R}  {msg}")
def _warn(msg: str) -> None: print(f"  {Y}!{R}  {msg}")
def _row(label: str, value: str) -> None:
    print(f"  {DIM}{label:<18}{R}{B}{value}{R}")


# ─────────────────────────────────────────────────────────────────────────────
# Command implementations  (unchanged logic, called both from TUI and CLI)
# ─────────────────────────────────────────────────────────────────────────────

HARNESS_PATHS = [".harness", "HARNESS.md", "HARNESS.html"]


def _select_research_agent(target: Path) -> str:
    """Interactive agent selection — shown FIRST in harness init.

    Shows ALL agents (installed + not installed). If user picks one that is not
    yet installed/authed, runs the install and auth flow before returning.

    Returns an agent name (e.g. "claude", "ollama:llama3.2") or "skip".
    """
    from harness_core.agent_research import (
        detect_agent_clis, install_agent_cli, run_agent_auth,
        _ollama_chat_models, _ollama_running,
    )
    from harness_core.tui import MenuItem, menu, confirm

    print()
    print(f"  {B}Select research agent{R}")
    _info("Chosen agent will deep-read the codebase and generate project-specific")
    _info("sections for HARNESS.html: architecture, modules, conventions, workflow.")
    print()

    while True:
        agents = detect_agent_clis()
        items: list[MenuItem] = []

        for a in agents:
            if a["available"]:
                icon  = f"{G}✓{R}"
                label = a["label"]
            elif a.get("installed") and not a.get("authed"):
                icon  = f"{Y}!{R}"
                label = a["label"] + "  (needs login)"
            else:
                icon  = f"{C}↓{R}"
                label = a["label"] + "  (not installed)"

            detail = a["detail"]
            if len(detail) > 62:
                detail = detail[:59] + "..."

            items.append(MenuItem(
                key=a["name"],
                label=label,
                desc=f"{icon}  {detail}",
            ))

        items.append(MenuItem(
            key="skip",
            label="Skip",
            desc=f"{DIM}generate HARNESS.html with standard sections only{R}",
        ))

        chosen = menu("Choose research agent:", items)
        if not chosen:
            _info("no agent selected — using standard sections only")
            return "skip"

        if chosen == "skip":
            return "skip"

        # Find the chosen agent entry
        agent = next((a for a in agents if a["name"] == chosen), None)
        if agent is None:
            return "skip"

        # Already fully available — done
        if agent["available"]:
            return chosen

        # ── Needs install ────────────────────────────────────────────────────
        if not agent["installed"]:
            how = agent.get("install_how")

            if how == "url":
                url = agent.get("auth_url") or "https://ollama.com/download"
                print()
                _warn(f"{agent['label']} cannot be auto-installed on this system.")
                _info(f"Download it from: {B}{url}{R}")
                try:
                    import subprocess as _sp
                    _sp.run(["open", url], check=False)
                    _info("Opened download page in your browser.")
                except Exception:
                    pass
                input(f"\n  Press Enter once {agent['label']} is installed... ")
                print()
                continue  # re-detect and redisplay menu

            if how in ("npm", "brew"):
                pkg  = agent.get("install_pkg", "")
                cmd_str = f"{'npm install -g' if how == 'npm' else 'brew install'} {pkg}"
                print()
                _info(f"{agent['label']} is not installed.")
                if not confirm(f"Install now via:  {B}{cmd_str}{R}  ?", default=True):
                    continue

                print()
                _info(f"Installing  {B}{pkg}{R} ...")
                ok = install_agent_cli(agent)
                if not ok:
                    _warn("install failed — choose another agent or fix manually")
                    input("  Press Enter to continue... ")
                    continue
                _ok(f"{agent['label']} installed")
                # Refresh PATH so shutil.which picks up the new binary
                import importlib, harness_core.agent_research as _ar
                importlib.reload(_ar)
                print()

            elif how == "ollama_pull":
                print()
                _info("Ollama is installed but no chat models are pulled yet.")
                _pick_ollama_model_to_pull()
                print()
                continue

            else:
                _warn(f"Don't know how to install {agent['label']} automatically.")
                input("  Press Enter to choose a different agent... ")
                continue

        # ── Needs auth ───────────────────────────────────────────────────────
        if agent["installed"] and not agent.get("authed"):
            print()
            _info(f"{agent['label']} is installed but needs authentication.")
            ok = run_agent_auth(agent)
            if not ok:
                _warn("auth failed or cancelled")
                input("  Press Enter to choose a different agent... ")
                continue
            _ok(f"{agent['label']} authenticated")
            print()

        # Re-run detection — if now available, return; else loop
        refreshed = next((a for a in detect_agent_clis() if a["name"] == chosen), None)
        if refreshed and refreshed["available"]:
            return chosen
        _warn("agent still not ready — check install/auth and try again")
        input("  Press Enter to retry... ")


def _pick_ollama_model_to_pull() -> None:
    """Let user pick and pull a chat model from the Ollama catalogue."""
    from harness_core.tui import MenuItem, menu

    _LLM_CATALOGUE = [
        ("qwen3:8b",         "5.2 GB", "fast reasoning, Vietnamese + EN"),
        ("qwen2.5-coder:7b", "4.7 GB", "code-optimised, context extraction"),
        ("llama3.2:3b",      "2.0 GB", "very fast, minimal RAM"),
        ("gemma3:4b",        "3.3 GB", "Google model, instruction following"),
        ("phi4-mini:3.8b",   "2.5 GB", "compact reasoning, low footprint"),
        ("mistral:7b",       "4.1 GB", "general-purpose, strong retrieval"),
    ]

    import subprocess
    items = [MenuItem(key=name, label=name, desc=f"{size}  —  {desc}")
             for name, size, desc in _LLM_CATALOGUE]
    items.append(MenuItem(key="skip", label="skip", desc="don't pull a model now"))

    chosen = menu("Select a model to pull:", items)
    if not chosen or chosen == "skip":
        _info("no model selected")
        return

    _info(f"Pulling  {B}{chosen}{R}  from Ollama registry ...")
    import sys as _sys
    proc = subprocess.Popen(["ollama", "pull", chosen],
                            stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                            text=True, bufsize=1)
    for line in proc.stdout or []:
        _sys.stdout.write(f"    {line}")
        _sys.stdout.flush()
    proc.wait()
    print()
    if proc.returncode == 0:
        _ok(f"{chosen} ready")
    else:
        _warn(f"pull failed for {chosen}")


def _refine_workflow(
    inferred: "dict | None",
    target: Path,
    agent_name: str,
    analysis: dict,
) -> "dict | None":
    """Show inferred workflow summary, then let user accept / review / free-text."""
    # ── display what was inferred ──────────────────────────────────────────────
    print()
    if inferred:
        _ok("Workflow inferred from git history:")
        _pairs = [
            ("ticket_system",  inferred.get("ticket_system") or "—"),
            ("ticket_url",     inferred.get("ticket_url") or "—"),
            ("base_branch",    inferred.get("base_branch") or "—"),
            ("branch_pattern", inferred.get("branch_pattern") or "—"),
            ("build_cmd",      inferred.get("build_cmd") or "—"),
        ]
        for k, v in _pairs:
            print(f"  {DIM}{k:<16}{R}  {v}")
        rules = inferred.get("critical_rules") or []
        if rules:
            print(f"  {DIM}{'critical_rules':<16}{R}  {rules[0]}")
            for r in rules[1:]:
                print(f"  {DIM}{'':<16}{R}  {r}")
    else:
        _warn("No workflow could be inferred — starting from defaults")

    # ── refinement menu ────────────────────────────────────────────────────────
    from harness_core.tui import MenuItem, menu as _menu
    wf_items = [
        MenuItem("accept",   "Accept as-is",
                             "Use inferred values — fastest option"),
        MenuItem("review",   "Review & edit each field",
                             "Pre-filled — press Enter to keep, type to override"),
        MenuItem("freetext", "Describe in your own words",
                             "Agent parses your plain-language description"),
        MenuItem("skip",     "Skip workflow",
                             "No workflow section in HARNESS.html"),
    ]
    print()
    choice = _menu("Workflow — what next?", wf_items)

    if choice is None or choice == "skip":
        _info("Skipping workflow section.")
        return None

    if choice == "accept":
        return inferred

    if choice == "review":
        return _workflow_review_mode(inferred, target)

    # freetext
    return _workflow_freetext_mode(inferred, target, agent_name, analysis)


def _workflow_review_mode(base: "dict | None", target: Path) -> "dict | None":
    """Interactive field-by-field review with pre-filled values from inference."""
    from harness_core.workflow_steps import WORKFLOW_GRILL_QUESTIONS, answers_to_workflow
    from harness_core.tui import prompt_input

    _field_map = {
        "wf_ticket_system":  (base or {}).get("ticket_system", ""),
        "wf_ticket_url":     (base or {}).get("ticket_url", ""),
        "wf_base_branch":    (base or {}).get("base_branch", ""),
        "wf_branch_pattern": (base or {}).get("branch_pattern", ""),
        "wf_context_files":  ", ".join((base or {}).get("context_files", [])),
        "wf_build_cmd":      (base or {}).get("build_cmd", ""),
        "wf_critical_rules": "\\n".join((base or {}).get("critical_rules", [])),
    }

    print()
    print(f"{DIM}Enter to keep inferred value  •  type to override  •  esc to finish{R}\n")
    answers: dict[str, str] = {}
    for item in WORKFLOW_GRILL_QUESTIONS:
        key     = item["key"]
        current = _field_map.get(key, "")
        hint    = f"  {DIM}[{current}]{R}" if current else ""
        print(f"{item['q']}{hint}")
        raw = prompt_input("> ")
        if raw is None:          # Esc — stop reviewing, keep what we have
            break
        answers[key] = raw if raw else current

    return answers_to_workflow(answers) if any(v for v in answers.values()) else base


def _workflow_freetext_mode(
    base: "dict | None",
    target: Path,
    agent_name: str,
    analysis: dict,
) -> "dict | None":
    """Let user describe workflow freely; agent extracts structured fields."""
    from harness_core.tui import prompt_input
    print()
    print(f"{DIM}Describe your ticket workflow in plain language. Examples:{R}")
    print(f"{DIM}  'We use OpenProject at op.bigin.vn. Tickets like OP-123.{R}")
    print(f"{DIM}   Branch from development as bug/OP-123. Build: msbuild PAGSWebRole.{R}")
    print(f"{DIM}   Never commit directly to development.'{R}")
    print()
    print("Your description (esc to cancel):")
    text = prompt_input("> ")
    if text is None:
        return base

    if not text:
        _warn("No description entered — keeping inferred values.")
        return base

    print()
    _info(f"Sending to {B}{agent_name}{R} for parsing...")
    try:
        from harness_core.agent_research import research_workflow_from_text
        result = research_workflow_from_text(target, agent_name, text, base)
        if result:
            return result
        _warn("Agent could not parse description — keeping inferred values.")
        return base
    except Exception as exc:
        _warn(f"Free-text parsing failed: {exc}")
        return base


def run_init(target: Path, *, dry_run: bool = False, skip_index: bool = False,
             from_analysis: str | None = None) -> int:
    from harness_core.project_init import analyze_project, init_project_full, is_initialized
    from harness_core.tui import confirm, menu, MenuItem

    # ── Detect re-init ────────────────────────────────────────────────────────
    force = False
    skip_research = False
    if is_initialized(target) and not dry_run:
        print()
        _info(f"{B}{target.name}{R} is already initialized.")
        _info(f"{DIM}Existing data (index, memory, features) will be preserved.{R}")
        _info(f"{DIM}Docs (HARNESS.md, HARNESS.html, MCP schema) will be refreshed.{R}")
        print()
        choice = menu(
            "What would you like to do?",
            [
                MenuItem("refresh", "Refresh docs + MCP",      "keep all data, regenerate HARNESS.html and MCP config"),
                MenuItem("research","Refresh + re-run research","re-run agent deep research, update HARNESS.html"),
                MenuItem("force",   "Full re-init",             "rebuild everything including index and memory (slow)"),
                MenuItem("cancel",  "Cancel",                   "exit without changes"),
            ],
            compact=True,
        )
        if choice is None or choice == "cancel":
            _info("Cancelled.")
            return 0
        if choice == "refresh":
            skip_research = True
        elif choice == "force":
            force = True
        # "research" → force=False, skip_research=False → normal re-init with research

    # ── Step 0: Agent selection ───────────────────────────────────────────────
    research_agent = "skip" if skip_research else _select_research_agent(target)
    print()

    print(f"\n{B}Analyzing{R} {DIM}{target.name}{R} ...")

    if from_analysis:
        p = Path(from_analysis).expanduser()
        if not p.exists():
            _warn(f"analysis file not found: {p}")
            return 2
        analysis = json.loads(p.read_text(encoding="utf-8"))
    else:
        analysis = analyze_project(target)

    lang      = analysis.get("language", "unknown")
    fw        = analysis.get("framework", "")
    secondary = analysis.get("secondary_languages", [])
    stack     = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(secondary)}" if secondary else "")
    _row("Stack",    stack)
    _row("Project",  analysis.get("project_name", target.name))
    entries = analysis.get("entry_points", [])
    if entries:
        _row("Entry points", str(len(entries)))

    agents = analysis.get("agents", [])
    if agents:
        names = ", ".join(a["agent"] for a in agents)
        _row("Agents found", names)

    if dry_run:
        _warn("dry-run — no files will be written")
        return 0

    # ── Step 1: Agent deep research ───────────────────────────────────────────
    agent_sections: dict | None = None
    if research_agent != "skip":
        print()
        # Show what extra context will be fed to the LLM
        from harness_core.project_analyzer import extract_doc_files
        _doc_files = extract_doc_files(target)
        _skill_n = len(_doc_files["skills"])
        _spec_n  = len(_doc_files["specs"])
        _doc_n   = len(_doc_files["docs"])
        _extras  = []
        if _skill_n: _extras.append(f"{_skill_n} skill{'s' if _skill_n>1 else ''}")
        if _spec_n:  _extras.append(f"{_spec_n} spec{'s' if _spec_n>1 else ''}")
        if _doc_n:   _extras.append(f"{_doc_n} doc{'s' if _doc_n>1 else ''}")
        _extra_str = f"  {DIM}+ {', '.join(_extras)}{R}" if _extras else f"  {DIM}(no skills/specs/docs found){R}"
        _info(f"Running deep research with  {B}{research_agent}{R} ...")
        _info(f"{DIM}Reading source files{R}{_extra_str}")
        try:
            from harness_core.agent_research import run_agent_research
            agent_sections = run_agent_research(target, research_agent, analysis)
            if agent_sections:
                section_count = len(agent_sections.get("sections", []))
                _ok(f"research complete  {DIM}{section_count} project-specific sections{R}")
            else:
                _warn("agent returned no structured content — using standard sections")
        except Exception as exc:
            _warn(f"agent research failed: {exc}")
            _info("continuing with standard sections")

        # ── workflow inference + user refinement ──────────────────────────────
        print()
        _info("Inferring ticket workflow from git history + CI config...")
        inferred_wf: dict | None = None
        try:
            from harness_core.agent_research import research_workflow
            inferred_wf = research_workflow(target, research_agent, analysis)
        except Exception as exc:
            _warn(f"workflow inference failed: {exc}")

        final_wf = _refine_workflow(inferred_wf, target, research_agent, analysis)
        if final_wf:
            from harness_core.workflow_steps import save_workflow
            save_workflow(target, final_wf)
            ts = final_wf.get("ticket_system") or "—"
            bc = final_wf.get("build_cmd") or "—"
            _ok(f"workflow saved  {DIM}ticket={ts}  build={bc}{R}")

    # Note which agent files are missing before init
    _missing_agent_files = [f for f in ("AGENTS.md", "CODEX.md") if not (target / f).exists()]
    if _missing_agent_files:
        _info(f"Generating {', '.join(_missing_agent_files)} via LLM (Ollama) or template ...")

    print()
    result = init_project_full(
        target, HARNESS_ROOT, analysis,
        dry_run=False, skip_index=skip_index, force=force,
        agent_sections=agent_sections,
    )

    _skipped = set(result.get("skipped", []))

    # ── show created/reused artifacts ────────────────────────────────────────
    artifacts = [
        (target / ".harness" / "index.json",   ".harness/index.json",   "BM25 search index"),
        (target / ".harness" / "memory.jsonl",  ".harness/memory.jsonl", "project memory"),
        (target / ".harness" / "mcp_schema.md", ".harness/mcp_schema.md","MCP tool reference"),
        (target / "HARNESS.md",                 "HARNESS.md",            "project guidelines"),
        (target / "HARNESS.html",               "HARNESS.html",          "visual architecture doc"),
    ]
    for path, label, desc in artifacts:
        if not path.exists():
            _warn(f"not created: {label}")
        elif str(path) in _skipped:
            _info(f"{DIM}{label}{R}  {DIM}unchanged (already exists){R}")
        else:
            _ok(f"{B}{label}{R}  {DIM}{desc}{R}")

    # ── MCP registration summary ──────────────────────────────────────────────
    print()
    _agent_files = ["CLAUDE.md", "AGENTS.md", "CODEX.md", "GEMINI.md"]
    injected  = [f for f in _agent_files
                 if (target / f).exists()
                 and "harness:start" in (target / f).read_text(encoding="utf-8", errors="ignore")]
    generated = [f for f in ("AGENTS.md", "CODEX.md")
                 if str(target / f) in result.get("created", [])]
    if generated:
        _ok(f"agent files generated  {DIM}{', '.join(generated)}{R}  {DIM}(via LLM or template){R}")
    if injected:
        _ok(f"harness block injected {DIM}{', '.join(injected)}{R}")
    if not injected and not generated:
        _warn("no agent files found — create CLAUDE.md/CODEX.md/GEMINI.md and re-run")

    _mcp_configs = {
        "Claude Code":       target / ".mcp.json",
        "Antigravity IDE":   Path.home() / ".gemini" / "antigravity-ide" / "mcp_config.json",
        "Antigravity CLI":   Path.home() / ".gemini" / "antigravity" / "mcp_config.json",
        "Gemini CLI":        Path.home() / ".gemini" / "config" / "mcp_config.json",
    }
    registered = []
    for label, cfg in _mcp_configs.items():
        if cfg.exists():
            try:
                d = json.loads(cfg.read_text(encoding="utf-8"))
                if "harness" in d.get("mcpServers", {}):
                    registered.append(label)
            except Exception:
                pass
    if registered:
        _ok(f"MCP registered  {DIM}{', '.join(registered)}{R}")
    else:
        _warn("MCP not registered — run:  harness mcp register")

    _info(f"{DIM}Restart agent IDE to load the new MCP server.{R}")

    # ── symlink (after artifacts, silent if already installed) ─────────────────
    _install_symlink(result)

    print()
    if not skip_index:
        _maybe_build_semantic_index(target)

    return 0


def run_update(target: Path) -> int:
    """harness update — pull latest harness, optionally refresh project files."""
    from harness_core.tui import pick2

    print()
    choice = pick2(
        "Harness update",
        left_label  = "Update harness",
        left_desc   = "pull latest from GitHub only",
        right_label = "Update + refresh project",
        right_desc  = "pull + regenerate docs/MCP for this project",
    )
    if choice is None:
        print("  cancelled")
        return 0

    update_project = (choice == "right")

    # ── Step 1: git pull in HARNESS_ROOT ─────────────────────────────────────
    import subprocess
    print()
    _info("Pulling latest harness from GitHub ...")

    result = subprocess.run(
        ["git", "-C", str(HARNESS_ROOT), "pull", "--ff-only", "origin", "main"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        _warn("git pull failed:")
        print(f"  {result.stderr.strip()}")
        return 1

    output = result.stdout.strip()
    if "Already up to date" in output:
        _ok("already up to date")
    else:
        for line in output.splitlines():
            _ok(line)

    if not update_project:
        print()
        _info("Done.  Run  harness mcp register  in each project to push new tool schemas.")
        return 0

    # ── Step 2: refresh project files (preserve data) ────────────────────────
    project_json = target / ".harness" / "project.json"
    if not project_json.exists():
        print()
        _warn(f"project not initialized — run  harness init  first: {target}")
        return 1

    print()
    _info(f"Refreshing project files for  {B}{target.name}{R} ...")
    _info(f"{DIM}memory, index, context_packs, workflow — preserved{R}")
    print()

    try:
        from harness_core.project_init import refresh_project_files
        r = refresh_project_files(target, HARNESS_ROOT)
    except Exception as exc:
        _warn(f"refresh failed: {exc}")
        return 1

    for path in r.get("refreshed", []):
        rel = path.replace(str(target) + "/", "").replace(str(Path.home()), "~")
        _ok(rel)

    preserved = r.get("preserved", [])
    if preserved:
        print()
        _info(f"Preserved ({len(preserved)}):  {DIM}{',  '.join(preserved)}{R}")

    print()
    _info("Restart agent IDE to reload the updated MCP server.")
    return 0


def run_eject(target: Path, *, dry_run: bool = False) -> int:
    removed: list[str] = []

    for rel in HARNESS_PATHS:
        path = target / rel
        if not path.exists():
            continue
        if dry_run:
            _info(f"would remove  {DIM}{rel}{R}")
        else:
            shutil.rmtree(path) if path.is_dir() else path.unlink()
            _ok(f"removed  {DIM}{rel}{R}")
        removed.append(rel)

    if not removed:
        _info("nothing to remove — project was not initialized")

    return 0


def run_analyze(target: Path) -> int:
    from harness_core.project_init import analyze_project

    print(f"\n{B}Analyzing{R} {DIM}{target.name}{R} ...")
    a = analyze_project(target)

    lang      = a.get("language", "unknown")
    fw        = a.get("framework", "")
    secondary = a.get("secondary_languages", [])
    stack     = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(secondary)}" if secondary else "")

    print()
    _row("Stack",    stack)
    _row("Project",  a.get("project_name", target.name))

    entries = a.get("entry_points", [])
    for i, e in enumerate(entries[:5]):
        label = "Entry points" if i == 0 else ""
        _row(label, Path(e).name)

    kw_research = a.get("routing_keywords", {}).get("research_heavy_keywords", [])
    kw_coding   = a.get("routing_keywords", {}).get("coding_keywords", [])
    if kw_research:
        _row("Research keys", ", ".join(kw_research[:5]))
    if kw_coding:
        _row("Coding keys",   ", ".join(kw_coding[:5]))

    features = a.get("initial_features", [])
    if features:
        print()
        _info(f"{len(features)} features seeded")
    memories = a.get("initial_memories", [])
    if memories:
        _info(f"{len(memories)} memory records ready")
    print()
    return 0


def run_grill(target: Path) -> int:
    from harness_core.project_analyzer import run_grill_session, write_grill_answers_to_harness_md
    from harness_core.project_init import analyze_project

    harness_md = target / "HARNESS.md"
    if not harness_md.exists():
        print("error: HARNESS.md not found — run init first")
        return 2

    project_json = target / ".harness" / "project.json"
    if project_json.exists():
        meta = json.loads(project_json.read_text(encoding="utf-8"))
        language     = meta.get("language", "unknown")
        framework    = meta.get("framework", "")
        project_name = meta.get("project_name", target.name)
    else:
        a = analyze_project(target)
        language, framework, project_name = a["language"], a["framework"], a["project_name"]

    answers = run_grill_session(target, language, framework, project_name)
    if not answers:
        print("\nNo answers recorded. HARNESS.md unchanged.")
        return 0

    write_grill_answers_to_harness_md(harness_md, answers)
    print(f"\n✓ {len(answers)} answer(s) written to {harness_md}")
    return 0


def run_index(target: Path) -> int:
    if not (target / ".harness").exists():
        print("error: not initialized — run init first")
        return 2
    _maybe_build_semantic_index(target)
    return 0


def run_center(target: Path, *, action: str, value: str | None = None) -> int:
    from harness_core.router import CENTERS, default_state, load_state, save_state

    valid = ("auto", *CENTERS)
    state_path = target / ".harness" / "state.json"
    state = load_state(state_path) if state_path.exists() else default_state()
    if action == "get":
        _row("Center", state.get("preferred_center", "auto"))
        return 0
    if action != "set":
        _warn(f"unknown center action: {action}")
        return 2
    if value not in valid:
        _warn(f"center must be one of: {', '.join(valid)}")
        return 2
    state["preferred_center"] = value
    save_state(state_path, state)
    _ok(f"project center set to  {B}{value}{R}")
    _info(f"saved  {DIM}{state_path}{R}")
    return 0


def _run_ollama_inline(model: str, prompt: str) -> None:
    """Stream an Ollama response to stdout."""
    import json as _json
    import urllib.request as _ur

    payload = _json.dumps({"model": model, "prompt": prompt, "stream": True}).encode()
    req = _ur.Request("http://localhost:11434/api/generate", data=payload,
                      headers={"Content-Type": "application/json"})
    try:
        with _ur.urlopen(req, timeout=300) as resp:
            for line in resp:
                token = _json.loads(line).get("response", "")
                sys.stdout.write(token)
                sys.stdout.flush()
        print()
    except Exception as exc:
        _warn(f"Ollama error: {exc}")


def run_ticket(
    target: Path,
    task: str,
    *,
    ticket_id: str | None = None,
    agent_name: str | None = None,
) -> int:
    """Build RAG pack for task, inject into prompt, then launch the selected agent.

    Agent cannot skip context loading — the pack is embedded in the prompt
    before the agent process starts.
    """
    import subprocess as _sp

    # ── 1. Build task-keyed RAG pack ─────────────────────────────────────────
    print()
    _info(f"Building context pack for:  {B}{task}{R}")
    from harness_core.agent_rag import build_agent_rag_pack
    try:
        report = build_agent_rag_pack(target, task, ticket_id=ticket_id)
        pack_path = Path(report["context_pack_path"])
        _ok(f"pack ready  {DIM}{pack_path.name}  (~{report['payload_tokens_estimate']} tokens){R}")
    except Exception as exc:
        _warn(f"RAG pack build failed: {exc}")
        _info("continuing without context pack")
        pack_path = None

    # ── 2. Load workflow critical rules ───────────────────────────────────────
    from harness_core.workflow_steps import load_workflow
    wf = load_workflow(target)

    # ── 3. Build combined prompt ──────────────────────────────────────────────
    parts: list[str] = []
    if pack_path and pack_path.exists():
        parts.append(pack_path.read_text(encoding="utf-8"))
    if wf:
        rules = wf.get("critical_rules") or []
        build_cmd = wf.get("build_cmd") or ""
        base_branch = wf.get("base_branch") or "main"
        branch_pattern = wf.get("branch_pattern") or ""
        if rules or build_cmd:
            rule_lines = "\n".join(f"- {r}" for r in rules)
            parts.append(
                f"## Project Rules (from .harness/workflow.json)\n\n"
                f"Base branch: `{base_branch}`\n"
                + (f"Branch pattern: `{branch_pattern}`\n" if branch_pattern else "")
                + (f"Verify with: `{build_cmd}`\n" if build_cmd else "")
                + (f"\nCritical rules:\n{rule_lines}\n" if rule_lines else "")
            )
    parts.append(f"## Task\n\n{task}")
    if ticket_id:
        parts[-1] = f"## Task (Ticket: {ticket_id})\n\n{task}"

    prompt = "\n\n---\n\n".join(parts)

    # ── 4. Resolve agent ──────────────────────────────────────────────────────
    resolved_agent = agent_name
    if not resolved_agent:
        # Read preferred agent from project state if available
        state_path = target / ".harness" / "state.json"
        if state_path.exists():
            try:
                import json as _json
                st = _json.loads(state_path.read_text())
                resolved_agent = st.get("preferred_agent") or st.get("preferred_center") or "claude"
            except Exception:
                resolved_agent = "claude"
        else:
            resolved_agent = "claude"

    # ── 5. Set env vars and launch ────────────────────────────────────────────
    env = os.environ.copy()
    env["HARNESS_TASK"] = task
    if ticket_id:
        env["HARNESS_TICKET_ID"] = ticket_id
    if pack_path:
        env["HARNESS_PACK_PATH"] = str(pack_path)

    print()
    _info(f"Launching  {B}{resolved_agent}{R}  with pre-loaded context...")
    print()

    try:
        if resolved_agent == "claude":
            cmd = ["claude", "--print", prompt]
            result = _sp.run(cmd, env=env, cwd=str(target))
        elif resolved_agent == "codex":
            cmd = ["codex", "exec", prompt]
            result = _sp.run(cmd, env=env, cwd=str(target))
        elif resolved_agent.startswith("ollama:"):
            model = resolved_agent[len("ollama:"):]
            _run_ollama_inline(model, prompt)
            return 0
        else:
            _warn(f"Unknown agent '{resolved_agent}'. Printing prompt to stdout instead.")
            print(prompt)
            return 0
        return result.returncode
    except FileNotFoundError:
        _warn(f"Agent '{resolved_agent}' not found. Install it or run `harness init` to configure.")
        _info("Prompt has been prepared — you can copy it manually:")
        print()
        print(prompt[:2000] + ("..." if len(prompt) > 2000 else ""))
        return 1


def run_rag_pack(target: Path, *, query: str, center: str = "project", local_model: str | None = None) -> int:
    from harness_core.agent_rag import build_agent_rag_pack

    report = build_agent_rag_pack(target, query, center=center, local_model=local_model)
    print()
    _ok(f"Context pack  {DIM}{report['context_pack_path']}{R}")
    _row("Center", str(report["center"]))
    _row("Sources", ", ".join(report["sources"]) or "none")
    _row("Local model", str(report["local_model"]))
    _row("Savings est.", f"{report['estimated_savings_percent']}%")
    print()
    _info("Agents should read the same pack before repo reasoning:")
    for name, command in report["commands"].items():
        if name == "refresh":
            continue
        _row(name, command)
    print()
    return 0 if report["verdict"] == "PASS" else 1


def run_status(target: Path) -> int:
    state_path   = target / ".harness" / "state.json"
    project_json = target / ".harness" / "project.json"
    memory_path  = target / ".harness" / "memory.jsonl"
    feature_path = target / ".harness" / "feature_list.json"
    semantic_idx = target / ".harness" / "indexes" / "semantic.json"

    print()
    if not state_path.exists():
        _warn("not initialized — run  harness init")
        return 0

    if project_json.exists():
        d    = json.loads(project_json.read_text(encoding="utf-8"))
        lang = d.get("language", "?")
        fw   = d.get("framework", "")
        sec  = d.get("secondary_languages", [])
        stack = f"{lang}" + (f"/{fw}" if fw else "") + (f"  +{', '.join(sec)}" if sec else "")
        _row("Project",   d.get("project_name", target.name))
        _row("Stack",     stack)
        _row("Analyzed",  d.get("analyzed_at", "")[:10])

        agents = d.get("agents", [])
        if agents:
            for i, a in enumerate(agents):
                label = "Agents" if i == 0 else ""
                _row(label, f"{a['agent']}  {DIM}{a['path']}{R}")

    if state_path.exists():
        state  = json.loads(state_path.read_text(encoding="utf-8"))
        center = state.get("preferred_center", "auto")
        _row("Center",    center)
    else:
        state = {}

    print()
    if memory_path.exists():
        n = sum(1 for l in memory_path.read_text(encoding="utf-8").splitlines() if l.strip())
        _row("Memory",    f"{n} records")
    else:
        _row("Memory",    "0 records")

    if feature_path.exists():
        features = json.loads(feature_path.read_text(encoding="utf-8")).get("features", [])
        done     = sum(1 for f in features if f.get("status") == "done")
        bar      = ("█" * done + "░" * (len(features) - done)) if features else ""
        _row("Features",  f"{done}/{len(features)}  {DIM}{bar}{R}")

    bm25 = target / ".harness" / "index.json"
    _row("BM25 index",  f"{G}ready{R}" if bm25.exists() else f"{Y}missing{R}")
    _row("Semantic idx", f"{G}ready{R}" if semantic_idx.exists() else f"{DIM}not built{R}")

    meta = json.loads(project_json.read_text(encoding="utf-8")) if project_json.exists() else {}
    llm = meta.get("local_llm")
    local_model = state.get("local_model", {})
    if llm and llm.get("enabled"):
        _row("Local LLM",  f"{G}{llm['model']}{R}  {DIM}context sub-agent{R}")
    elif local_model.get("enabled"):
        _row("Local LLM",  f"{G}{local_model.get('model', 'ollama')}{R}  {DIM}{local_model.get('role', 'rag_distiller')}{R}")
    else:
        _row("Local LLM",  f"{DIM}not configured{R}")
    # RAG pack — resolve symlink to show real file name
    pack_sym = target / ".harness" / "context_packs" / "last-rag-pack.md"
    if pack_sym.is_symlink() or pack_sym.exists():
        real = pack_sym.resolve() if pack_sym.is_symlink() else pack_sym
        _row("RAG pack",  f"{G}ready{R}  {DIM}{real.name}{R}")
    else:
        _row("RAG pack",  f"{DIM}not built — run: harness rag-pack \"<task>\"{R}")

    # MCP server health
    mcp_cfg = target / ".harness" / "mcp.json"
    if mcp_cfg.exists():
        try:
            mcp_data = json.loads(mcp_cfg.read_text(encoding="utf-8"))
            servers  = mcp_data.get("mcpServers", {})
            ok_list  = []
            bad_list = []
            for sname, scfg in servers.items():
                cmd = scfg.get("command", "")
                if cmd and shutil.which(cmd) or Path(cmd).exists():
                    ok_list.append(sname)
                else:
                    bad_list.append(sname)
            if bad_list:
                _row("MCP server",  f"{Y}!{R}  command not found: {', '.join(bad_list)}  {DIM}(run: python3 -m harness_mcp.server){R}")
            elif ok_list:
                _row("MCP server",  f"{G}configured{R}  {DIM}{', '.join(ok_list)}{R}")
            else:
                _row("MCP server",  f"{DIM}no servers in mcp.json{R}")
        except Exception:
            _row("MCP server",  f"{DIM}mcp.json unreadable{R}")
    else:
        _row("MCP server",  f"{Y}!{R}  .harness/mcp.json missing — run: harness init")

    # Agent instruction files
    _AGENT_FILES = ["CLAUDE.md", "AGENTS.md", "CODEX.md", "GEMINI.md"]
    injected = [f for f in _AGENT_FILES if (target / f).exists() and "harness:start" in (target / f).read_text(encoding="utf-8", errors="ignore")]
    missing  = [f for f in _AGENT_FILES if (target / f).exists() and "harness:start" not in (target / f).read_text(encoding="utf-8", errors="ignore")]
    if injected:
        _row("Agent rules",  f"{G}injected{R}  {DIM}{', '.join(injected)}{R}")
    if missing:
        _row("Agent rules",  f"{Y}!{R}  harness block missing in: {', '.join(missing)}  {DIM}(re-run: harness init){R}")
    if not injected and not missing:
        _row("Agent rules",  f"{DIM}no agent files found — create CLAUDE.md/CODEX.md/GEMINI.md{R}")

    # Lifecycle hooks
    hooks_path = target / ".harness" / "hooks.json"
    if hooks_path.exists():
        hooks_data = json.loads(hooks_path.read_text(encoding="utf-8"))
        h_count = len([h for h in hooks_data.get("hooks", []) if h.get("enabled", True)])
        _row("Hooks",      f"{h_count} active")
    else:
        _row("Hooks",      f"{DIM}not configured{R}")

    # Per-project growth
    growth_dir = target / ".harness" / "growth"
    if growth_dir.exists():
        pd_path = growth_dir / "pattern_db.jsonl"
        patterns = sum(1 for l in pd_path.read_text(encoding="utf-8").splitlines() if l.strip()) if pd_path.exists() else 0
        ev_path  = growth_dir / "routing_evidence.jsonl"
        evidence = sum(1 for l in ev_path.read_text(encoding="utf-8").splitlines() if l.strip()) if ev_path.exists() else 0
        _row("Growth",     f"{patterns} patterns  {DIM}{evidence} routing records{R}")
    else:
        _row("Growth",     f"{DIM}not bootstrapped{R}")

    # Trajectories
    traj_dir = target / ".harness" / "trajectories"
    if traj_dir.exists():
        traj_files = list(traj_dir.glob("*.json"))
        success_n  = 0
        fail_n     = 0
        for tf in traj_files[-20:]:
            try:
                d = json.loads(tf.read_text(encoding="utf-8"))
                if d.get("outcome") == "success": success_n += 1
                elif d.get("outcome") == "failure": fail_n += 1
            except Exception:
                pass
        _row("Trajectories", f"{len(traj_files)} total  {DIM}{success_n}✓ {fail_n}✗ (last 20){R}")

    # Recent telemetry
    telemetry_dir = target / ".harness" / "telemetry"
    if telemetry_dir.exists():
        chain_files = list(telemetry_dir.glob("chain_*.json"))
        _row("Telemetry",  f"{len(chain_files)} chains recorded")
    print()
    return 0


def run_mcp(target: Path, action: str) -> int:
    """harness mcp status|register|unregister"""
    from harness_core.mcp_registration import (
        mcp_registration_status, register_mcp_project, register_mcp_global, unregister_mcp,
    )

    project_json = target / ".harness" / "project.json"
    if not project_json.exists():
        _warn("not initialized — run  harness init  first")
        return 1

    meta = json.loads(project_json.read_text(encoding="utf-8"))
    harness_root = Path(meta.get("harness_root", HARNESS_ROOT))

    if action == "status":
        status = mcp_registration_status(target, harness_root)
        print()

        # Schema doc
        schema_path = target / ".harness" / "mcp_schema.md"
        if schema_path.exists():
            lines = schema_path.read_text(encoding="utf-8").count("\n")
            _row("MCP schema", f"{G}ready{R}  {DIM}{lines} lines → {schema_path}{R}")
        else:
            _row("MCP schema", f"{Y}missing{R}  — run:  harness mcp register")

        # Agent instruction files
        _AGENT_FILES = ["CLAUDE.md", "AGENTS.md", "CODEX.md", "GEMINI.md"]
        injected = [f for f in _AGENT_FILES
                    if (target / f).exists()
                    and "harness:start" in (target / f).read_text(encoding="utf-8", errors="ignore")]
        if injected:
            _row("Agent rules", f"{G}injected{R}  {DIM}{', '.join(injected)}{R}")
        else:
            _row("Agent rules", f"{Y}missing{R}  — create CLAUDE.md/CODEX.md/GEMINI.md then re-run")

        print()

        # Config registration
        _labels = {
            "claude_project":      "Claude (project)",
            "antigravity_ide":     "Antigravity IDE",
            "antigravity_global":  "Antigravity CLI",
            "gemini_config":       "Gemini CLI",
        }
        all_ok = True
        for key, label in _labels.items():
            val = status.get(key, "unknown")
            if val == "registered":
                _row(label, f"{G}registered{R}")
            elif val == "file absent":
                _row(label, f"{DIM}not installed{R}")
            else:
                _row(label, f"{Y}missing{R}  — run:  harness mcp register")
                all_ok = False
        print()
        if not all_ok:
            _info("Run  harness mcp register  to register in all installed agents.")
        return 0

    if action == "register":
        # Regenerate schema doc first (agents read it from agent instruction files)
        try:
            from harness_core.mcp_schema import write_mcp_schema, generate_compact_tier1_md
            schema_path = write_mcp_schema(target, harness_root)
            _ok(f"schema → {schema_path}")
        except Exception as exc:
            _warn(f"schema generation failed: {exc}")

        # Re-inject agent instruction files with updated schema block
        from harness_core.project_init import inject_agent_instructions
        updated = inject_agent_instructions(target, harness_root)
        for f in updated:
            _ok(f"agent rules → {f}")

        written = register_mcp_project(target, harness_root)
        written += register_mcp_global(harness_root)
        print()
        if written:
            for p in written:
                _ok(p)
            print()
            _info("Restart your agent IDE / terminal session for the change to take effect.")
        else:
            _warn("no config files written — check permissions or re-run after installing agents")
        return 0

    if action == "unregister":
        removed = unregister_mcp(target)
        print()
        if removed:
            for p in removed:
                _ok(f"removed harness from  {p}")
        else:
            _info("harness was not registered in any config files")
        return 0

    print(f"unknown mcp action: {action}", file=sys.stderr)
    return 1


# ─────────────────────────────────────────────────────────────────────────────
# Curated model catalogue
# ─────────────────────────────────────────────────────────────────────────────

# Embedding models — first one is the recommended default
_EMBED_CATALOGUE = [
    ("nomic-embed-text",     "137 MB", "best balance — fast, accurate, widely used"),
    ("mxbai-embed-large",    "670 MB", "high accuracy, larger memory footprint"),
    ("bge-m3",               "1.2 GB", "multilingual — EN/VI/ZH/JP supported"),
    ("all-minilm",           "46 MB",  "ultra-fast, low RAM — good for large repos"),
    ("snowflake-arctic-embed","335 MB","optimised for code search"),
]

# LLM sub-agent models for context retrieval
_LLM_CATALOGUE = [
    ("qwen3:8b",            "5.2 GB", "fast reasoning, Vietnamese + EN, low VRAM"),
    ("qwen2.5-coder:7b",    "4.7 GB", "code-optimised, great for context extraction"),
    ("llama3.2:3b",         "2.0 GB", "very fast, minimal RAM — quick summarisation"),
    ("gemma3:4b",           "3.3 GB", "Google model, good at instruction following"),
    ("phi4-mini:3.8b",      "2.5 GB", "compact reasoning, low footprint"),
    ("mistral:7b",          "4.1 GB", "general-purpose, strong at retrieval tasks"),
]


def _pull_ollama_model(model: str) -> bool:
    """Stream `ollama pull <model>` and return True on success."""
    import subprocess
    _info(f"pulling  {B}{model}{R}  from Ollama registry ...")
    try:
        proc = subprocess.run(
            ["ollama", "pull", model],
            check=True,
        )
        return proc.returncode == 0
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        _warn(f"pull failed: {exc}")
        return False


# ─────────────────────────────────────────────────────────────────────────────
# Semantic index + local LLM sub-agent setup
# ─────────────────────────────────────────────────────────────────────────────

def _maybe_build_semantic_index(target: Path) -> None:
    from harness_core.semantic_index import detect_ollama, build_semantic_index, ollama_embed
    from harness_core.tui import confirm, MenuItem, menu

    embed_models, other_models = detect_ollama()
    ollama_running = bool(embed_models or other_models)

    # ── Embedding index ────────────────────────────────────────────────────────
    if not ollama_running:
        _warn("Ollama not running — semantic index skipped")
        _info("install Ollama, then:  harness  →  index")
    else:
        if confirm("Build semantic RAG index with Ollama?", default=True):
            _build_embed_index(target, embed_models, other_models)

    # ── Local LLM sub-agent ────────────────────────────────────────────────────
    print()
    _info("Local LLM sub-agents help cloud models (Claude / Codex / Antigravity)")
    _info("by pre-fetching and summarising context before the main agent call.")
    if confirm("Configure a local LLM sub-agent for context retrieval?", default=False):
        _configure_local_llm(target, other_models)
    else:
        _info("local LLM skipped — configure later:  harness  →  index")


def _build_embed_index(target: Path, embed_models: list[str], other_models: list[str]) -> None:
    from harness_core.semantic_index import build_semantic_index, ollama_embed
    from harness_core.tui import MenuItem, menu, confirm

    items: list[MenuItem] = []

    # Only show true embedding models — chat models are not listed
    for m in embed_models:
        # find description from catalogue if available
        desc = next((d for (name, _, d) in _EMBED_CATALOGUE if m.split(":")[0] == name.split(":")[0]), "embedding model")
        items.append(MenuItem(key=m, label=m, desc=f"✓  {desc}"))

    if not embed_models:
        # Offer to pull a recommended embedding model
        _warn("no embedding model installed")
        print()
        pull_items = [
            MenuItem(key=name, label=name, desc=f"{size}  —  {desc}")
            for name, size, desc in _EMBED_CATALOGUE
        ]
        pull_items.append(MenuItem(key="skip", label="skip", desc="skip — do not build semantic index"))
        to_pull = menu("Pull an embedding model from Ollama:", pull_items)
        if not to_pull or to_pull == "skip":
            _info("semantic index skipped")
            return
        if not _pull_ollama_model(to_pull):
            _warn("could not pull model — semantic index skipped")
            return
        chosen = to_pull
    else:
        # Also offer pull option at the bottom
        pull_item = MenuItem(key="__pull__", label="pull new model…",
                             desc="download a recommended embedding model from Ollama")
        items.append(pull_item)
        chosen_key = menu("Select embedding model:", items)
        if chosen_key is None:
            _info("semantic index skipped")
            return
        if chosen_key == "__pull__":
            pull_items = [
                MenuItem(key=name, label=name, desc=f"{size}  —  {desc}")
                for name, size, desc in _EMBED_CATALOGUE
                if not any(m.startswith(name.split(":")[0]) for m in embed_models)
            ] or [MenuItem(key=name, label=name, desc=f"{size}  —  {desc}") for name, size, desc in _EMBED_CATALOGUE]
            to_pull = menu("Choose model to pull:", pull_items)
            if not to_pull:
                _info("semantic index skipped")
                return
            if not _pull_ollama_model(to_pull):
                _warn("could not pull model — semantic index skipped")
                return
            chosen = to_pull
        else:
            chosen = chosen_key

    index_path = target / ".harness" / "indexes" / "semantic.json"
    index_path.parent.mkdir(parents=True, exist_ok=True)

    print()
    _info(f"building semantic index with  {B}{chosen}{R} ...")

    # Pre-count chunks so we can show accurate progress
    from harness_core.semantic_index import _chunk_repository, _load_existing
    existing = _load_existing(index_path, chosen)
    cached_keys = {(c["key"], c["content_hash"]) for c in existing.get("chunks", [])}
    all_chunks  = _chunk_repository(target, chunk_lines=40, overlap_lines=8)
    total_chunks = len(all_chunks)
    missing_n    = sum(1 for c in all_chunks if (c["key"], c["content_hash"]) not in cached_keys)
    reused_n     = total_chunks - missing_n

    if missing_n == 0:
        _ok(f"semantic index up to date  {DIM}{total_chunks} chunks  (all cached){R}")
        return

    _info(f"{total_chunks} chunks total  {DIM}({missing_n} to embed, {reused_n} cached){R}")
    batch_size = 64
    n_batches  = (missing_n + batch_size - 1) // batch_size

    # Progress bar helper (inline ANSI, no extra lines)
    import sys as _sys
    _prog_line = [""]
    def _progress(done: int, total: int) -> None:
        pct   = done * 100 // max(total, 1)
        filled = pct // 5          # 20 blocks wide
        bar   = f"{G}{'█' * filled}{DIM}{'░' * (20 - filled)}{R}"
        batch_n = (done + batch_size - 1) // batch_size
        line  = f"\r  {C}·{R}  {bar}  {pct:3d}%  {DIM}batch {batch_n}/{n_batches}  ({done}/{total}){R}   "
        _sys.stdout.write(line)
        _sys.stdout.flush()
        _prog_line[0] = line

    try:
        stats = build_semantic_index(
            target, index_path,
            embedder=lambda t: ollama_embed(t, model=chosen),
            model=chosen,
            batch_size=batch_size,
            progress_cb=_progress,
        )
        # Clear progress line and print result
        _sys.stdout.write("\r" + " " * (len(_prog_line[0]) + 4) + "\r")
        _sys.stdout.flush()
        total   = stats.get("chunk_count", "?")
        reused  = stats.get("reused_count", 0)
        new_vec = stats.get("embedded_count", total)
        _ok(f"semantic index ready  {DIM}{total} chunks  ({new_vec} embedded, {reused} cached){R}")
    except Exception as exc:
        _sys.stdout.write("\n")
        _warn(f"semantic index failed: {exc}")
        _info("fix: ollama pull nomic-embed-text  then retry: harness  →  index")


def _configure_local_llm(target: Path, installed_llms: list[str]) -> None:
    from harness_core.tui import MenuItem, menu

    items: list[MenuItem] = []

    # Installed LLMs first (excluding tiny or embedding-only)
    for m in installed_llms:
        desc = next(
            (f"{sz}  —  {d} (installed)" for (name, sz, d) in _LLM_CATALOGUE
             if m.split(":")[0] == name.split(":")[0]),
            "installed chat/code model",
        )
        items.append(MenuItem(key=m, label=m, desc=f"✓  {desc}"))

    # Offer pullable models not yet installed
    for name, size, desc in _LLM_CATALOGUE:
        if not any(m.split(":")[0] == name.split(":")[0] for m in installed_llms):
            items.append(MenuItem(key=f"__pull__{name}", label=f"{name}  ↓",
                                  desc=f"{size}  —  {desc}  (will pull)"))

    items.append(MenuItem(key="skip", label="skip", desc="no local LLM sub-agent"))

    chosen = menu("Select local LLM for context sub-agent:", items)
    if not chosen or chosen == "skip":
        _info("local LLM sub-agent skipped")
        return

    if chosen.startswith("__pull__"):
        model_name = chosen[len("__pull__"):]
        if not _pull_ollama_model(model_name):
            _warn("could not pull model")
            return
        chosen = model_name

    # Persist to project.json
    project_json = target / ".harness" / "project.json"
    try:
        meta = json.loads(project_json.read_text(encoding="utf-8")) if project_json.exists() else {}
        meta["local_llm"] = {
            "model":   chosen,
            "role":    "context_retrieval",
            "host":    "http://localhost:11434",
            "enabled": True,
        }
        project_json.write_text(
            json.dumps(meta, indent=2, ensure_ascii=False) + "\n", encoding="utf-8"
        )
        _ok(f"local LLM sub-agent  {B}{chosen}{R}  configured")
        print()
        _info("How it works:")
        _info(f"  cloud agent (Claude/Codex) calls harness_contextual_context_pack")
        _info(f"  harness routes context queries to  {B}{chosen}{R}  locally")
        _info(f"  summarised context is injected into the cloud agent's prompt")
        _info(f"  net effect: cheaper cloud calls, faster context retrieval")
    except Exception as exc:
        _warn(f"could not save local LLM config: {exc}")


def _install_symlink(result: dict) -> None:
    this_script = Path(__file__).resolve()
    candidates  = [Path("/usr/local/bin/harness"), Path.home() / ".local" / "bin" / "harness"]
    symlink: Path | None = None

    for candidate in candidates:
        try:
            candidate.parent.mkdir(parents=True, exist_ok=True)
            if candidate.is_symlink() or candidate.exists():
                if Path(os.readlink(candidate)).resolve() == this_script:
                    result["symlink"] = str(candidate)   # already installed, silent
                    return
                candidate.unlink()
            candidate.symlink_to(this_script)
            symlink = candidate
            break
        except PermissionError:
            continue

    if symlink is None:
        _warn("could not install harness command (permission denied)")
        return

    _ok(f"installed  {DIM}{symlink}{R}")
    result["symlink"] = str(symlink)

    if symlink.parent == Path.home() / ".local" / "bin":
        _ensure_path(symlink.parent)


def _ensure_path(bin_dir: Path) -> None:
    marker = str(bin_dir)
    for rc in (Path.home() / ".zshrc", Path.home() / ".bashrc"):
        if rc.exists() and marker in rc.read_text(encoding="utf-8"):
            return
    zshrc = Path.home() / ".zshrc"
    try:
        with zshrc.open("a", encoding="utf-8") as f:
            f.write(f'\nexport PATH="{marker}:$PATH"  # added by harness init\n')
        _info(f"added {DIM}{marker}{R} to PATH in ~/.zshrc — run: source ~/.zshrc")
    except OSError as exc:
        _warn(f"could not update ~/.zshrc: {exc}")


# ─────────────────────────────────────────────────────────────────────────────
