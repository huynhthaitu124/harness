#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.experiment_quality import evaluate_experiment_output  # noqa: E402


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: harness-experiment-quality <output.json>", file=sys.stderr)
        return 2
    output = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
    report = evaluate_experiment_output(ROOT, output)
    print(json.dumps(report, indent=2, ensure_ascii=False))
    return 0 if report["verdict"] == "PASS" else 1


if __name__ == "__main__":
    raise SystemExit(main())
