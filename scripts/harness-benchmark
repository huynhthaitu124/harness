#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.context_budget import build_context_pack, measure_context_savings  # noqa: E402


def main() -> int:
    if len(sys.argv) < 3:
        print("usage: harness-benchmark <repo-or-folder> <query>", file=sys.stderr)
        return 2
    root = Path(sys.argv[1]).expanduser().resolve()
    query = " ".join(sys.argv[2:])
    pack = build_context_pack(root, query)
    result = {
        "root": str(root),
        "query": query,
        **measure_context_savings(root, pack),
        "context_pack_chars": len(pack),
    }
    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
