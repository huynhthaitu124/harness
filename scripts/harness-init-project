#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.project_init import init_project_harness  # noqa: E402


def main() -> int:
    if len(sys.argv) < 3:
        print("usage: harness-init-project <repo-or-folder> <feature...>", file=sys.stderr)
        return 2
    result = init_project_harness(Path(sys.argv[1]).expanduser(), sys.argv[2:])
    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
