#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.router import default_state, load_state, save_state  # noqa: E402

STATE = ROOT / ".harness" / "state.json"


def main() -> int:
    state = load_state(STATE)
    if len(sys.argv) == 1 or sys.argv[1] in {"status", "get"}:
        print(json.dumps(state, indent=2, ensure_ascii=False))
        return 0
    if sys.argv[1] == "init":
        save_state(STATE, default_state())
        print(f"initialized {STATE}")
        return 0
    if sys.argv[1] == "set" and len(sys.argv) == 3:
        center = sys.argv[2]
        if center not in {"auto", "codex", "claude", "antigravity"}:
            print("center must be one of: auto, codex, claude, antigravity", file=sys.stderr)
            return 2
        state["preferred_center"] = center
        save_state(STATE, state)
        print(f"preferred_center={center}")
        return 0
    print("usage: harness-center [status|get|init|set <auto|codex|claude|antigravity>]", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())

