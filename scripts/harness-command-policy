#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.command_policy import validate_command  # noqa: E402


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: harness-command-policy <command>", file=sys.stderr)
        return 2
    result = validate_command(" ".join(sys.argv[1:]), actor="autopilot")
    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0 if result["verdict"] == "ALLOW" else 1


if __name__ == "__main__":
    raise SystemExit(main())
