#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.readiness import build_readiness_report  # noqa: E402
from harness_core.router import load_state  # noqa: E402


def run(command: list[str]) -> str:
    env = os.environ.copy()
    env["PATH"] = f"{Path.home() / '.local/bin'}:{env.get('PATH', '')}"
    try:
        result = subprocess.run(command, text=True, capture_output=True, timeout=20, check=False, env=env)
    except (OSError, subprocess.TimeoutExpired):
        return ""
    return f"{result.stdout}\n{result.stderr}"


def machine_state() -> dict[str, int]:
    swap = run(["sysctl", "vm.swapusage"])
    match = re.search(r"total = ([0-9.]+)M\s+used = ([0-9.]+)M", swap)
    pressure = run(["memory_pressure"])
    free_match = re.search(r"System-wide memory free percentage: (\d+)%", pressure)
    return {
        "swap_total_mb": int(float(match.group(1))) if match else 1,
        "swap_used_mb": int(float(match.group(2))) if match else 0,
        "memory_free_percent": int(free_match.group(1)) if free_match else 0,
    }


def main() -> int:
    codex = run(["codex", "mcp", "list"])
    claude = run([str(Path.home() / ".local/bin" / "claude"), "mcp", "list"])
    antigravity = run([str(Path.home() / ".local/bin" / "agy"), "plugins", "list"])
    ollama_ps = run(["ollama", "ps"])
    probes = {
        "codex": {"installed": shutil.which("codex") is not None, "harness_connected": "harness" in codex and "enabled" in codex},
        "claude": {"installed": (Path.home() / ".local/bin" / "claude").exists(), "harness_connected": "harness:" in claude and "Connected" in claude},
        "antigravity": {"installed": (Path.home() / ".local/bin" / "agy").exists(), "harness_connected": "tri-center-harness" in antigravity},
    }
    local_probe = {
        "installed": shutil.which("ollama") is not None,
        "model_loaded": len([line for line in ollama_ps.splitlines() if line.strip()]) > 1,
    }
    report = build_readiness_report(
        load_state(ROOT / ".harness" / "state.json"),
        probes=probes,
        local_probe=local_probe,
        machine=machine_state(),
    )
    print(json.dumps(report, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
