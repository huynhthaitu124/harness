#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.feature_state import complete_feature, init_feature_list, next_feature  # noqa: E402


def main() -> int:
    if len(sys.argv) < 3:
        print("usage: harness-features init|next|complete <path> [...]", file=sys.stderr)
        return 2
    action = sys.argv[1]
    path = Path(sys.argv[2]).expanduser()
    if action == "init":
        features = sys.argv[3:]
        if not features:
            print("provide at least one feature title", file=sys.stderr)
            return 2
        print(json.dumps(init_feature_list(path, features), indent=2, ensure_ascii=False))
        return 0
    if action == "next":
        print(json.dumps(next_feature(path), indent=2, ensure_ascii=False))
        return 0
    if action == "complete":
        if len(sys.argv) < 5:
            print("usage: harness-features complete <path> <feature_id> <evidence...>", file=sys.stderr)
            return 2
        print(json.dumps(complete_feature(path, int(sys.argv[3]), sys.argv[4:]), indent=2, ensure_ascii=False))
        return 0
    print(f"unknown action: {action}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
