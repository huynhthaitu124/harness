#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.evaluator import evaluate_evidence  # noqa: E402


def main() -> int:
    if len(sys.argv) < 4:
        print("usage: harness-evaluate <root> <required-comma-list> <evidence...>", file=sys.stderr)
        return 2
    root = Path(sys.argv[1]).expanduser()
    required = [item.strip() for item in sys.argv[2].split(",") if item.strip()]
    evidence = sys.argv[3:]
    print(json.dumps(evaluate_evidence(root, required, evidence), indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
