#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

HARNESS_PATHS = [
    ".harness",
    "HARNESS.md",
    "HARNESS.html",
    "configs/claude-mcp.json",
]


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Remove harness config from a project while keeping production_artifacts data.",
        usage="harness-eject <target-project-path> [--dry-run]",
    )
    parser.add_argument("target", help="Path to the target project directory")
    parser.add_argument("--dry-run", action="store_true", help="Print what would be removed without deleting")
    args = parser.parse_args()

    target = Path(args.target).expanduser().resolve()
    if not target.exists():
        print(f"error: path does not exist: {target}", file=sys.stderr)
        return 2

    removed: list[str] = []
    skipped: list[str] = []

    for rel in HARNESS_PATHS:
        path = target / rel
        if not path.exists():
            skipped.append(rel)
            continue
        if args.dry_run:
            kind = "dir" if path.is_dir() else "file"
            print(f"  [dry-run] would remove {kind}: {path}", file=sys.stderr)
        else:
            if path.is_dir():
                shutil.rmtree(path)
            else:
                path.unlink()
        removed.append(str(path))

    configs_dir = target / "configs"
    if configs_dir.exists() and not any(configs_dir.iterdir()):
        if args.dry_run:
            print(f"  [dry-run] would remove empty dir: {configs_dir}", file=sys.stderr)
        else:
            configs_dir.rmdir()
        removed.append(str(configs_dir))

    kept = str(target / "production_artifacts")
    result = {
        "root": str(target),
        "dry_run": args.dry_run,
        "removed": removed,
        "skipped": skipped,
        "kept": kept,
    }
    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
