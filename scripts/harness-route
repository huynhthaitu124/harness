#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.router import choose_center, load_state  # noqa: E402
from harness_core.token_ledger import summarize_usage  # noqa: E402

STATE = ROOT / ".harness" / "state.json"
LEDGER = ROOT / "production_artifacts" / "usage.jsonl"


def main() -> int:
    task = " ".join(sys.argv[1:]).strip()
    if not task:
        print("usage: harness-route <task>", file=sys.stderr)
        return 2
    usage = summarize_usage(LEDGER)
    print(json.dumps(choose_center(task, load_state(STATE), usage_summary=usage), indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
