#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.search_index import build_index, search_index  # noqa: E402


def main() -> int:
    if len(sys.argv) < 4:
        print("usage: harness-index build <root> <index> | search <index> <query>", file=sys.stderr)
        return 2
    action = sys.argv[1]
    if action == "build":
        print(json.dumps(build_index(Path(sys.argv[2]).expanduser(), Path(sys.argv[3]).expanduser()), ensure_ascii=False))
        return 0
    if action == "search":
        print(json.dumps(search_index(Path(sys.argv[2]).expanduser(), " ".join(sys.argv[3:])), indent=2, ensure_ascii=False))
        return 0
    print(f"unknown action: {action}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
