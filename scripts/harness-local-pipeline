#!/usr/bin/env python3
from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.local_rag_pipeline import plan_local_rag_pipeline  # noqa: E402


def machine_state() -> dict[str, int]:
    swap = subprocess.run(["sysctl", "vm.swapusage"], text=True, capture_output=True, check=False)
    match = re.search(r"total = ([0-9.]+)M\s+used = ([0-9.]+)M", swap.stdout)
    pressure = subprocess.run(["memory_pressure"], text=True, capture_output=True, check=False)
    free_match = re.search(r"System-wide memory free percentage: (\d+)%", pressure.stdout)
    return {
        "swap_total_mb": int(float(match.group(1))) if match else 1,
        "swap_used_mb": int(float(match.group(2))) if match else 0,
        "memory_free_percent": int(free_match.group(1)) if free_match else 0,
    }


def models() -> list[str]:
    result = subprocess.run(["ollama", "list"], text=True, capture_output=True, check=False)
    return [line.split()[0] for line in result.stdout.splitlines()[1:] if line.split()]


def main() -> int:
    if len(sys.argv) < 3:
        print("usage: harness-local-pipeline <chunk-count> <task>", file=sys.stderr)
        return 2
    plan = plan_local_rag_pipeline(
        " ".join(sys.argv[2:]),
        chunk_count=int(sys.argv[1]),
        machine=machine_state(),
        installed_models=models(),
    )
    print(json.dumps(plan, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
