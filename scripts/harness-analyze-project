#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.project_init import analyze_project  # noqa: E402


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: harness-analyze-project <target-project-path>", file=sys.stderr)
        return 2

    target_root = Path(sys.argv[1]).expanduser().resolve()
    if not target_root.exists():
        print(f"error: path does not exist: {target_root}", file=sys.stderr)
        return 2

    analysis = analyze_project(target_root)
    print(json.dumps(analysis, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
