#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.capability_registry import evaluate_capability, list_capabilities, promote_capability  # noqa: E402
from harness_core.capability_scaffold import scaffold_capability  # noqa: E402


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: harness-capabilities list [root] | scaffold <name> <description> | evaluate|promote <name> <evidence...>", file=sys.stderr)
        return 2
    action = sys.argv[1]
    if action == "list":
        root = Path(sys.argv[2]).expanduser() if len(sys.argv) > 2 else ROOT
        print(json.dumps(list_capabilities(root), indent=2, ensure_ascii=False))
        return 0
    if action == "scaffold" and len(sys.argv) >= 4:
        print(json.dumps(scaffold_capability(ROOT, sys.argv[2], " ".join(sys.argv[3:])), indent=2, ensure_ascii=False))
        return 0
    if action in {"evaluate", "promote"} and len(sys.argv) >= 4:
        function = promote_capability if action == "promote" else evaluate_capability
        result = function(ROOT, sys.argv[2], evidence=sys.argv[3:])
        print(json.dumps(result, indent=2, ensure_ascii=False))
        return 0 if result["verdict"] == "PASS" else 1
    print("usage: harness-capabilities list [root] | scaffold <name> <description> | evaluate|promote <name> <evidence...>", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
