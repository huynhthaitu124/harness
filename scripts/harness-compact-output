#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.output_compactor import compact_tool_output  # noqa: E402


def main() -> int:
    max_chars = int(sys.argv[2]) if len(sys.argv) > 2 else 4000
    if len(sys.argv) > 1 and sys.argv[1] != "-":
        text = Path(sys.argv[1]).read_text(encoding="utf-8", errors="ignore")
    else:
        text = sys.stdin.read()
    print(json.dumps(compact_tool_output(text, max_chars=max_chars), indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
