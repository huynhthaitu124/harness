#!/usr/bin/env python3
from __future__ import annotations

import json
import re
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.semantic_index import build_semantic_index, ollama_embed, plan_semantic_index, search_semantic_index  # noqa: E402


def machine_state() -> dict[str, int]:
    swap = subprocess.run(["sysctl", "vm.swapusage"], text=True, capture_output=True, check=False)
    match = re.search(r"total = ([0-9.]+)M\s+used = ([0-9.]+)M", swap.stdout)
    pressure = subprocess.run(["memory_pressure"], text=True, capture_output=True, check=False)
    free_match = re.search(r"System-wide memory free percentage: (\d+)%", pressure.stdout)
    return {
        "swap_total_mb": int(float(match.group(1))) if match else 1,
        "swap_used_mb": int(float(match.group(2))) if match else 0,
        "memory_free_percent": int(free_match.group(1)) if free_match else 0,
    }


def installed_models() -> list[str]:
    result = subprocess.run(["ollama", "list"], text=True, capture_output=True, check=False)
    return [line.split()[0] for line in result.stdout.splitlines()[1:] if line.split()]


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: harness-semantic-index plan [model] | build <root> <index> [model] | search <index> <query> [model]", file=sys.stderr)
        return 2
    action = sys.argv[1]
    if action == "plan":
        model = sys.argv[2] if len(sys.argv) > 2 else None
    elif action in {"build", "search"}:
        model = sys.argv[4] if len(sys.argv) > 4 else None
    else:
        model = None
    plan = plan_semantic_index(machine=machine_state(), installed_models=installed_models(), model=model)
    selected_model = plan["model"]
    if action == "plan":
        print(json.dumps(plan, indent=2, ensure_ascii=False))
        return 0
    if not plan["use_ollama"]:
        print(json.dumps(plan, indent=2, ensure_ascii=False))
        return 1
    if action == "build" and len(sys.argv) >= 4:
        embedder = lambda texts: ollama_embed(texts, model=selected_model)
        print(json.dumps(build_semantic_index(Path(sys.argv[2]), Path(sys.argv[3]), embedder=embedder, model=selected_model), indent=2))
        return 0
    if action == "search" and len(sys.argv) >= 4:
        embedder = lambda texts: ollama_embed(texts, model=selected_model)
        print(json.dumps(search_semantic_index(Path(sys.argv[2]), sys.argv[3], embedder=embedder), indent=2, ensure_ascii=False))
        return 0
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
