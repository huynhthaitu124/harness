#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from harness_core.mcp_security import audit_mcp_security  # noqa: E402
from harness_mcp.server import TOOLS  # noqa: E402


def main() -> int:
    server_text = (ROOT / "harness_mcp" / "server.py").read_text(encoding="utf-8")
    report = audit_mcp_security(server_text=server_text, tools=TOOLS)
    print(json.dumps(report, indent=2, ensure_ascii=False))
    return 0 if report["verdict"] == "PASS" else 1


if __name__ == "__main__":
    raise SystemExit(main())
